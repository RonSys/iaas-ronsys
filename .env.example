# ═══════════════════════════════════════════════════════════════
#  IaaS-RonSys — Variables de Entorno
#  Archivo ÚNICO. Copiar como .env en la raíz del proyecto.
#  docker-compose.yml lo lee automáticamente y lo distribuye
#  a cada servicio.
# ═══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────
APP_NAME=IaaS-RonSys
APP_VERSION=0.1.0
DEBUG=true

# ─── PostgreSQL ──────────────────────────────────────────────
# Para desarrollo local sin Docker:
DATABASE_URL=postgresql+asyncpg://ron:ron123@localhost:5432/iaas_ronsys
# Para Docker (el hostname es el nombre del servicio):
DATABASE_URL_DOCKER=postgresql+asyncpg://ron:ron123@postgres:5432/iaas_ronsys

POSTGRES_USER=ron
POSTGRES_PASSWORD=ron123
POSTGRES_DB=iaas_ronsys
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_URL_DOCKER=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=iaas-tasks
RABBITMQ_MANAGEMENT_PORT=15672

# ─── LLM / IA ────────────────────────────────────────────────
LLM_API_KEY=sk-tu-api-key-aqui
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai

# ─── Auth / Seguridad ───────────────────────────────────────
# ⚠️  Generar con: openssl rand -hex 32
#     NUNCA hardcodear en archivos .py
SECRET_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2

# ─── Monitoreo ───────────────────────────────────────────────
METRICS_ENABLED=true
OTEL_SERVICE_NAME=iaas-ronsys-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Backend ─────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour

# ─── Grafana ─────────────────────────────────────────────────
GRAFANA_PORT=3000

# ─── Prometheus ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
