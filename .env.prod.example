# ═══════════════════════════════════════════════════════════════
#  IaaS-RonSys — Variables de Entorno (Producción)
#
#  Copiar como .env.prod y ajustar valores.
#  BD: iaas_ronsys
#  Puerto backend: 8000, frontend nginx: 80
# ═══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────
APP_NAME=IaaS-RonSys
APP_VERSION=0.1.0
DEBUG=false

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ron:ron123@localhost:5432/iaas_ronsys
DATABASE_URL_DOCKER=postgresql+asyncpg://ron:ron123@postgres:5432/iaas_ronsys

POSTGRES_USER=ron
POSTGRES_PASSWORD=***
POSTGRES_DB=iaas_ronsys
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_URL_DOCKER=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=iaas-tasks
RABBITMQ_MANAGEMENT_PORT=15672

# ─── Auth / Seguridad ───────────────────────────────────────
# ⚠️  Generar con: openssl rand -hex 32
SECRET_KEY=

# ─── Backend ─────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour

# ─── Monitoreo ───────────────────────────────────────────────
METRICS_ENABLED=true
