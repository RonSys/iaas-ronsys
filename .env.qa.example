# ═══════════════════════════════════════════════════════════════
#  IaaS-RonSys — Variables de Entorno (QA)
#
#  Copiar como .env.qa y ajustar valores.
#  BD separada: iaas_ronsys_qa
#  Puerto backend: 8001
# ═══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────
APP_NAME=IaaS-RonSys-QA
APP_VERSION=0.1.0-qa
DEBUG=true

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ron:ron123@localhost:5432/iaas_ronsys_qa
DATABASE_URL_DOCKER=postgresql+asyncpg://ron:ron123@postgres:5432/iaas_ronsys_qa

POSTGRES_USER=ron
POSTGRES_PASSWORD=***
POSTGRES_DB=iaas_ronsys_qa
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_URL_DOCKER=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=iaas-tasks
RABBITMQ_MANAGEMENT_PORT=15672

# ─── Auth / Seguridad ───────────────────────────────────────
# ⚠️  Generar con: openssl rand -hex 32
SECRET_KEY=

# ─── Backend ─────────────────────────────────────────────────
BACKEND_PORT=8001
BACKEND_HOST=0.0.0.0

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour

# ─── Monitoreo ───────────────────────────────────────────────
METRICS_ENABLED=true
